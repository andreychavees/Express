# =============================================
# CONFIGURAÇÃO DO RASTREIO CORREIOS
# =============================================
# Copie este arquivo para .env e preencha os valores

# Porta do servidor (padrão: 3000)
PORT=3000

# =============================================
# EMAIL (obrigatório para notificações por email)
# =============================================
# Use seu Gmail + Senha de App (não a senha normal!)
# Para criar senha de app: myaccount.google.com > Segurança > Senhas de app
EMAIL_USER=seu@gmail.com
EMAIL_PASS=sua-senha-de-app-gmail

# =============================================
# AFTERSHIP (principal — rastreamento universal)
# =============================================
# Obtenha sua API key em: app.aftership.com > Configurações > API
AFTERSHIP_API_KEY=asat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================
# LINKETRACK (opcional - backup de rastreamento)
# =============================================
# Crie conta gratuita em linketrack.com para maior cota
LINKETRACK_USER=teste
LINKETRACK_TOKEN=1abcd00b2731640422b9e7e3fdc96668d47

# =============================================
# TWILIO SMS (opcional - para notificações por SMS)
# =============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# =============================================
# AUTENTICAÇÃO
# =============================================
# Segredo para assinar os tokens JWT (gere um aleatório em produção)
JWT_SECRET=seu-jwt-secret-aleatorio-aqui

# Email com acesso admin automático
ADMIN_EMAIL=seu@gmail.com

# ID do cliente OAuth do Google (para login com Google)
# Obtenha em: console.cloud.google.com → Credenciais → Criar cliente OAuth 2.0
GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
